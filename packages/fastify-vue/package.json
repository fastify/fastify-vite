{
  "name": "@fastify/vue",
  "version": "1.2.3",
  "description": "The official @fastify/vite renderer for Vue",
  "keywords": [
    "fastify",
    "vite",
    "vue"
  ],
  "homepage": "https://vite.fastify.dev/vue/",
  "bugs": {
    "url": "https://github.com/fastify/fastify-vite/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fastify/fastify-vite.git"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.test.*",
    "virtual/**/*",
    "virtual-ts/**/*",
    "virtual.d.ts"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-file-parallelism"
  },
  "dependencies": {
    "@fastify/vite": "workspace:^",
    "@unhead/vue": "^3.0.0",
    "acorn": "^8.12.1",
    "acorn-walk": "^8.3.4",
    "devalue": "catalog:",
    "mlly": "^1.5.0",
    "vue": "catalog:vue",
    "vue-router": "catalog:vue",
    "youch": "^3.3.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "catalog:vue",
    "fastify": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.6"
  }
}
