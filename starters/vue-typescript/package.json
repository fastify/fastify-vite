{
  "name": "vue-typescript-starter",
  "private": true,
  "description": "TypeScript starter template for @fastify/vue",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts --dev",
    "start": "node dist/server.js",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc",
    "typecheck": "vue-tsc --noEmit -p src/client/tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/vite": "^9.0.0",
    "@fastify/vue": "workspace:^",
    "@unhead/vue": "^3.0.0",
    "fastify": "^5.8.4",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vue-tsc": "^3.2.6"
  }
}
